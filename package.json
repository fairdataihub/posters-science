{
  "name": "posters-science",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "lint:js": "eslint .",
    "lint:prettier": "prettier --check .",
    "lint": "pnpm lint:js && pnpm lint:prettier",
    "lint:fix": "prettier --write --list-different . && pnpm lint:js --fix",
    "prisma:generate": "prisma generate",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:migrate:dev": "prisma migrate dev",
    "prisma:migrate:dev:create-only": "prisma migrate dev --create-only",
    "prisma:studio": "prisma studio",
    "prisma:db:push": "prisma db push",
    "prisma:db:pull": "prisma db pull",
    "postinstall": "nuxt prepare && prisma generate",
    "reset": "rm -rf node_modules && rm -rf .nuxt && rm -rf .output && rm -rf dist && pnpm install",
    "prune-branches": "git removed-branches --prune --force",
    "test:upload": "npx tsx scripts/upload-test-posters.ts",
    "test:dummy": "npx tsx scripts/create-dummy-posters.ts"
  },
